{
    "name": "easybounce",
    "version": "1.0.2",
    "description": "EasyBounce — Logic Pro stem bouncer",
    "main": "main.js",
    "productName": "EasyBounce",
    "scripts": {
        "start": "electron .",
        "build": "electron-builder --mac dmg",
        "pack": "electron-builder --mac dir",
        "build:arm64": "electron-builder --mac dir --arm64",
        "build:x64": "electron-builder --mac dir --x64",
        "build:universal": "electron-builder --mac dir --universal",
        "release": "bash build_release.sh"
    },
    "devDependencies": {
        "electron": "^33.4.11",
        "electron-builder": "^24.0.0"
    },
    "build": {
        "appId": "com.easybounce.app",
        "productName": "EasyBounce",
        "directories": {
            "output": "dist"
        },
        "mac": {
            "category": "public.app-category.music",
            "icon": "assets/icon.icns",
            "extendInfo": {
                "NSAppleEventsUsageDescription": "EasyBounce needs to control Logic Pro and System Events to automate bouncing.",
                "NSSystemAdministrationUsageDescription": "EasyBounce needs to automate Logic Pro."
            },
            "target": [
                {
                    "target": "dir",
                    "arch": [
                        "arm64",
                        "x64"
                    ]
                }
            ]
        },
        "files": [
            "main.js",
            "preload.js",
            "license.js",
            "license.html",
            "notifications.js",
            "src/**",
            "LogicBridge",
            "CloseLogicWindows",
            "assets/**"
        ],
        "asarUnpack": [
            "LogicBridge",
            "CloseLogicWindows"
        ]
    },
    "dependencies": {}
}
