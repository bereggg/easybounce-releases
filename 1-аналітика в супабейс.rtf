  ROUND(AVG((mode_time->>'easy')::int)) AS avg_easy_sec,\
  ROUND(AVG((mode_time->>'pro')::int)) AS avg_pro_sec,\
  ROUND(AVG((mode_time->>'compact')::int)) AS avg_compact_sec\
