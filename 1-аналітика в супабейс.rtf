SELECT category, metric, value FROM (\
  -- \uc0\u1047 \u1072 \u1075 \u1072 \u1083 \u1086 \u1084 \
  SELECT 1 AS ord, 'GENERAL' AS category, 'Total sessions' AS metric, COUNT(*)::text AS value FROM analytics_sessions\
  UNION ALL SELECT 1, 'GENERAL', 'Unique users', COUNT(DISTINCT machine_id)::text FROM analytics_sessions\
  UNION ALL SELECT 1, 'GENERAL', 'Avg session (min)', ROUND(AVG(duration_sec)/60.0, 1)::text FROM analytics_sessions\
\
  -- Bounces\
  UNION ALL SELECT 2, 'BOUNCES', 'Total bounces', COALESCE(SUM((bounces->>'count')::int), 0)::text FROM analytics_sessions\
  UNION ALL SELECT 2, 'BOUNCES', 'Total render hours', ROUND(SUM(render_time_total_sec)/3600.0, 1)::text FROM analytics_sessions\
  UNION ALL SELECT 2, 'BOUNCES', 'Avg channels/scan', ROUND(AVG(channels_avg))::text FROM analytics_sessions WHERE channels_avg IS NOT NULL\
\
  -- Top buttons (\uc0\u1090 \u1086 \u1087 -5)\
  UNION ALL SELECT 3, 'TOP BUTTONS', key, SUM((value)::int)::text\
    FROM analytics_sessions, jsonb_each_text(buttons)\
    WHERE buttons <> '\{\}'::jsonb\
    GROUP BY key ORDER BY SUM((value)::int) DESC LIMIT 5\
\
  -- Formats\
  UNION ALL SELECT 4, 'FORMATS', key, SUM((value)::int)::text\
    FROM analytics_sessions, jsonb_each_text(bounces->'formats')\
    WHERE bounces->'formats' IS NOT NULL\
    GROUP BY key\
\
  -- Types (stem/mix/group)\
  UNION ALL SELECT 5, 'BOUNCE TYPES', key, SUM((value)::int)::text\
    FROM analytics_sessions, jsonb_each_text(bounces->'types')\
    WHERE bounces->'types' IS NOT NULL\
    GROUP BY key\
\
  -- macOS versions\
  UNION ALL SELECT 6, 'macOS', os_version, COUNT(*)::text\
    FROM analytics_sessions WHERE os_version IS NOT NULL\
    GROUP BY os_version ORDER BY COUNT(*) DESC\
\
  -- Architecture\
  UNION ALL SELECT 7, 'ARCH', mac_arch, COUNT(*)::text\
    FROM analytics_sessions WHERE mac_arch IS NOT NULL\
    GROUP BY mac_arch\
\
  -- Logic versions\
  UNION ALL SELECT 8, 'LOGIC', logic_version, COUNT(*)::text\
    FROM analytics_sessions WHERE logic_version IS NOT NULL\
    GROUP BY logic_version ORDER BY COUNT(*) DESC LIMIT 5\
\
  -- Mode usage (avg seconds per session)\
  UNION ALL SELECT 9, 'MODE TIME (avg sec)', 'easy',    ROUND(AVG((mode_time->>'easy')::int))::text    FROM analytics_sessions WHERE mode_time IS NOT NULL\
  UNION ALL SELECT 9, 'MODE TIME (avg sec)', 'pro',     ROUND(AVG((mode_time->>'pro')::int))::text     FROM analytics_sessions WHERE mode_time IS NOT NULL\
  UNION ALL SELECT 9, 'MODE TIME (avg sec)', 'compact', ROUND(AVG((mode_time->>'compact')::int))::text FROM analytics_sessions WHERE mode_time IS NOT NULL\
  UNION ALL SELECT 9, 'MODE TIME (avg sec)', 'mini',    ROUND(AVG((mode_time->>'mini')::int))::text    FROM analytics_sessions WHERE mode_time IS NOT NULL\
\
  -- Top errors\
  UNION ALL SELECT 10, 'ERRORS', key, SUM((value)::int)::text\
    FROM analytics_sessions, jsonb_each_text(errors)\
    WHERE errors IS NOT NULL\
    GROUP BY key ORDER BY SUM((value)::int) DESC LIMIT 5\
) t\
ORDER BY ord, category, value::int DESC NULLS LAST;\
\
